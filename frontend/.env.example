# Deployed Lambda Function URL (US-8). Not committed with a real value --
# it's not secret (the Function URL has no auth), but treating it like any
# other Bedrock/AWS resource identifier in this project: never hardcode a
# live one into committed defaults, since it can change if the underlying
# resource is ever replaced. Copy this file to .env.local and fill in the
# current value:
#
#   aws cloudformation describe-stacks --stack-name LambdaProxyStack \
#     --region us-east-1 \
#     --query "Stacks[0].Outputs[?OutputKey=='FunctionUrlOutput'].OutputValue" \
#     --output text
#
# Leave unset to fall back to the local mock streaming backend.
VITE_FUNCTION_URL=
